ShieldCoreWizard: {
	DisplayName: 符文法师护甲核心
	Tooltip: ""
	CoreLevel1: 攻击时追加三道追踪的符文魔法
	CoreLevel2: 每道符文魔法的伤害倍率从33%提升至50%
	CoreLevel3: 每道符文魔法的伤害倍率从50%提升至100%
}
