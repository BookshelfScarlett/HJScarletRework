ClimaticHawstring: {
	DisplayName: 气候钓弦
	Tooltip:
		'''
		击中敌人一定次数时，接下来的5秒内会连续发射热能激光
		攻击时会有两位小型飞棍仆从协助攻击
		“以天竿为弓，以气候为弦”
		'''
}

BambooRocket: {
	DisplayName: 火箭竹
	Tooltip: 发射会追踪的竹
}

TerraFlamethrower: {
	DisplayName: 泰拉喷火器
	Tooltip:
		'''
		使你的敌人沐浴于璀璨夺目的泰拉之光
		按下右键投掷燃素手雷，命中敌人时爆炸，对施加泰拉燃素
		泰拉燃素效果会使敌人从身上不断滴落泰拉精华，伤害取敌人接触伤害的100%
		泰拉精华不会对被施加泰拉燃素的敌人造成伤害
		80%概率不消耗凝胶
		'''
}

