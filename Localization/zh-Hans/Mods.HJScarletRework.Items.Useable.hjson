CorePickaxe: {
	DisplayName: 地核镐
	Tooltip:
		'''
		一把足够炙热，能够为你熔炼矿物的工具……
		该功能在多人模式下暂时禁用
		"地球中心"
		'''
}

TerrariaRecipe: {
	DisplayName: 泰拉瑞亚食谱
	Tooltip:
		'''
		启用时使你依据吃下去的食物种类数量提供生命上限加成
		每食用5份提供10点生命上限加成
		右键以开关
		"这可不是《我的世界》"
		'''
	Eaten: 已食用：允许提供生命上限
	NotEaten: 还没尝过呢！要不要试试看？
	Active: 当前状态：已启用，可通过按下左Alt查看食物清单
	FoodList:
		'''
		已食用（{2})
		{0}
		未食用（{3}）
		{1}
		'''
}
