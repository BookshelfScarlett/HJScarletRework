SouloftheTidalMark: {
	DisplayName: 澪标之魂
	Tooltip:
		'''
		攻击命中时恢复20点生命值
		你的生命值永远不会低于5点，但仍然会受到致死的伤害
		'''
}

HeartoftheCrystal: {
	DisplayName: 水晶之心
	Tooltip:
		'''
		所有的魔法武器不再消耗任何魔力
		增加15%魔法暴击概率
		使你造成的魔法伤害乘算降低20%
		'''
}

HeartoftheMountain: {
	DisplayName: 山之心
	Tooltip:
		'''
		所有的魔法武器不再消耗任何魔力
		增加50%魔法暴击概率
		使你造成的魔法伤害10.0x
		'''
}

PreciousAim: {
	DisplayName: 精准打击
	Tooltip:
		'''
		将暴击概率设定为20%
		造成暴击时增加5%暴击概率，最大增加125%暴击概率
		将你溢出的暴击概率1比1转化为暴击伤害加成
		达到最大暴击上限识，强化大部分由你直接发射出去的低速弹幕的飞行速度
		受到伤害时重置
		'''
}

PreciousTarget: {
	DisplayName: 精确瞄准
	Tooltip:
		'''
		将暴击概率设定为10%
		造成暴击时增加5%暴击概率，最大增加115%暴击概率
		将你溢出的暴击概率1比1转化为暴击伤害加成
		受到伤害时重置
		"似乎有点眼熟"
		'''
}

ExecutorsSwordMarkPlus: {
	DisplayName: 处刑者剑章 A++
	Tooltip:
		'''
		处决攻击在满足条件时变为按下 互动键 手动触发
		手动触发处决攻击后，使你接下来的一定时间内造成的代行者伤害1.1x
		并且，使你的代行者伤害必定造成暴击
		在触发伤害加成期间，再次执行处决攻击不会刷新这个效果
		'''
}

ExecutorsSwordMark: {
	DisplayName: 处刑者剑章 A+
	Tooltip:
		'''
		处决攻击在满足条件时变为按下 互动键 手动触发
		手动触发处决攻击时，你的代行者伤害必定造成暴击
		'''
}

CrimsonRune: {
	DisplayName: 猩红护符
	Tooltip:
		'''
		大幅度增加生命再生速度
		缩短25%治疗药水的冷却时间
		'''
}

