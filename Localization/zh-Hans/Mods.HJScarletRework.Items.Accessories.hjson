		'''
}

HeartoftheRuinFrost: {
	DisplayName: 霜封的王国之心
	Tooltip:
		'''
		+{0} 最大生命上限
		免疫击退、岩浆、寒冷、冰冻、霜火和冻伤
		允许玩家冲入敌人，撞击时低概率直接冻结
		允许玩家水下呼吸
		获得冰冻护盾所有效果
		“那曾经繁华一时的异界王国如今崩毁沉寂于暴雪之中”
		'''
}

ExecutorsSwordMarkSmall: {
	DisplayName: 处刑者剑章
	Tooltip:
		'''
		处决攻击在满足条件时变为按下 互动键 手动触发
		手动触发处决攻击时，你的代行者伤害以50%概率造成暴击，这一效果独立计算
		'''
}

HeartoftheDistantArk: {
