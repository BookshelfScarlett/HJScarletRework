}

CycleMadness: {
	DisplayName: 轮回疯狂
	Tooltip:
		'''
		将代行者的暴击概率重设定为0%
		造成代行者伤害时，总会以一定的概率掉落[i:HJScarletRework/MadnessCritStar]暴击之星
		拾取一枚暴击之星会增加5%的暴击概率，最大增加至200%
		该暴击概率加成在每次拾取时都会刷新持续时间
		'''
}

