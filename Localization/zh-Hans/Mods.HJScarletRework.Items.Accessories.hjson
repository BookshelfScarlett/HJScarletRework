		免疫击退、伊卡洛斯和所有火系减益
		'''
}

CrimsonCharm: {
	DisplayName: 嗜血面具
	Tooltip:
		'''
		使你彻底免疫药水疾病
		所有治疗药水的治疗量增加{3}
		每使用一次治疗药水都会使你获得治疗饱和的效果{1}秒
		在治疗饱和期间再次使用治疗药水，会减少{0}点治疗量，直至{2}点
		大幅度增强生命恢复速度
		“难以想象为了活下去竟如此疯狂”
		'''
}

BitingClaw: {
