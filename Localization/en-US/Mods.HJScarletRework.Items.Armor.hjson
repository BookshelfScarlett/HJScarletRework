	DisplayName: Red Dragon Knight Helmet
	Tooltip:
		'''
		15% increased executor damage
		10% increased executor critcal strike chance
		'''
	SetBouns:
		'''
		25% increased melee attack speed, 1.10x damage for all consumable ranged weapon
		Magic weapons no longer cost any mana with the cost of 20% damage, reset max minions and sentry slots to 1
		All weapons that do not deal executor damage only benefit from executor damage bonuses
		All weapons that do not deal executor damage instead deal executor damage type On Hit, rather than their original damage type
		'''
}

