FloretProtectorExecutor: {
	HelmetTooltip: 30% increased executor damage and critcal strike chance
	ChestplateTooltip:
		'''
		10% increased executor damage
		Granted immnuity to knockback
		'''
	LegsTooltip:
		'''
		5% increased executor damage and critcal strike chance
		20% increased movement speed
		'''
	SetBonus:
		'''
		+100 max health
		Always has multiple herbs floating around you from time to time
		Pick them up when nearby, and gain different effects based on the herb picked up
		Gain the Forest Herb for 5 seconds on first pickup, subsequent pickups do not refresh this duration
		Picking up herbs while already having the Forest Herb buff will Heal you for a certain amount
		Hold Left Alt to view detailed herb effects
		'''
	BuffDetail:
		'''
		[i:Daybloom]Daybloom:
		+30 defense, +4 HP/s health regeneration, makes you glow
		When already under Forest Herb buff: +10 defense, +2 HP/s health regeneration
		[i:Moonglow]Moonglow:
		12% increased damage reduction, reduces damage from behind by 65%, lowers enemy aggro
		When already under Forest Herb buff: 8% increased damage reduction, reduces damage from behind by 25%
		[i:Deathweed]Deathweed:
		20% increased executor damage and critical strike chance, greatly increases enemy aggro
		When already under Forest Herb buff: increases executor damage and critical strike chance by 10%
		[i:Fireblossom]Fireblossom:
		35% increased executor damage and critical strike chance while in lava
		When already under Forest Herb buff: 15% increased executor damage and critical strike chance
		[i:Waterleaf]Waterleaf:
		+50 luck, nearly all right-clickable loot bags/crates grant you coins
		When already under Forest Herb buff: +25 luck
		[i:Blinkroot]Blinkroot:
		50% increased mining speed, grants all effects related to mining
		When already under Forest Herb buff: increases mining speed by 30%
		[i:Shiverthorn]Shiverthorn:
		Has a 1/4 chance to deal an extra 1.15x damage on hit
		When already under Forest Herb buff: has a 1/4 chance to deal an extra 1.10x damage on hit
		'''
}

FishCostumeExecutor: {
	HelmetTooltip: 5% increased executor damage
	ChestplateTooltip: Allows you breath in the water
