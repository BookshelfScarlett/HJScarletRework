CreationHat: {
	DisplayName: Creation Alchemist's Hat
	Tooltip: Pairing it with a robe may yield unexpected results…
	SetBonus:
		'''
		+{0} defense and + {1} max mana
		{2}%, increased magic damage, {4}%  increased magic critical strike chance
		Reduces mana cost by {3}%, allows all magic attacks to deal critical strike damage
		Excess critical strike chance is converted to your magic critical strike damage bonus at a 1:2 ratio
		'''
}

