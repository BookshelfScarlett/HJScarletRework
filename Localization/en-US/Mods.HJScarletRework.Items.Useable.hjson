CorePickaxe: {
	DisplayName: Core Pickaxe
	Tooltip:
		'''
		A tool hot enough to smelt ores for you��
		This feature is temporarily disabled in multiplayer mode
		��Center of the Earth��
		'''
}

TerrariaRecipe: {
	DisplayName: Terraria Recipe
	Tooltip:
		'''
		Grants a bonus to maximum health based on the number of different food types consumed
		Gains 10 max health for every 5 food items consumed
		Right-click to toggle
		"This isn't Minecraft."
		'''
	Eaten: Eaten: Allows max health bonus
	NotEaten: '''"Not eaten yet! Want to give it a try?"'''
	Active: ""
	FoodList:
		'''
		Eaten ({2})
		{0}
		Not eaten ({3})
		{1}
		'''
}

